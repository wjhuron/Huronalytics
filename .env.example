# Supabase Postgres connection — copy this file to `.env` and fill in your real values.
# `.env` is gitignored; this `.env.example` is the committed, secret-free template.
#
# Where to find it: Supabase dashboard -> Project Settings (gear) -> Database ->
# Connection string -> use the "Session pooler" URI (works over IPv4).
# Replace [YOUR-PASSWORD] with your database password.
#
# Example shape (do NOT put a real password in this file):
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres
